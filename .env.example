# Gaia mobile app / staging proxy configuration
# Copy to your backend host environment only. Do not commit real values.

# Public static app URL, used for CORS and generated embed snippets.
APP_PUBLIC_URL=https://gaiagitshare.github.io/gaia-healers-mobile-app/
PROXY_PUBLIC_URL=https://ba2ki.com/gaia-proxy

# Comma-separated allowed origins for the staging proxy.
ALLOWED_ORIGINS=https://gaiagitshare.github.io,https://gaiagitshare.github.io/gaia-healers-mobile-app,https://crm.gaiahealers.com

# Gaia member auth/session. Keep backend-only.
AUTH_SESSION_SECRET=
AUTH_SESSION_COOKIE=gaia_member_session
AUTH_SESSION_TTL_SECONDS=604800
AUTH_MAGIC_LINK_TTL_SECONDS=900
AUTH_ALLOW_DEBUG_LINKS=false
AUTH_ALLOW_UNVERIFIED_EMAIL_MAGIC_LINK=false
AUTH_EMBED_SHARED_SECRET=
AUTH_TRUSTED_REFERRERS=https://crm.gaiahealers.com,https://education.gaiahealers.com

# GoHighLevel / LeadConnector API. Keep these backend-only.
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=
GHL_API_TOKEN=
GHL_API_VERSION=2021-07-28

# Academy / courses progress. Keep backend-only.
# Option A: point to a normalized internal endpoint that returns member course progress JSON.
ACADEMY_PROGRESS_BASE_URL=
ACADEMY_PROGRESS_TOKEN=
# Option B: staging-only normalized JSON export pasted as one env var.
ACADEMY_PROGRESS_JSON=
ACADEMY_PROGRESS_MEMBER_ID=
ACADEMY_PROGRESS_EMAIL=

# Full member hub sync: portal, communities, meetings, marketplace, newsletter.
# Option A: point to a normalized internal endpoint that returns member hub JSON.
MEMBER_HUB_BASE_URL=
MEMBER_HUB_TOKEN=
# Option B: staging-only normalized JSON export pasted as one env var.
MEMBER_HUB_JSON=
MEMBER_HUB_MEMBER_ID=
MEMBER_HUB_EMAIL=

# Gaia Event Manager. Keep admin tokens backend-only.
EVENT_MANAGER_BASE_URL=https://ba2ki.com/event-api
EVENT_MANAGER_TOKEN=
EVENT_MANAGER_EVENT_ID=1

# Gaia Assist / voice. Keep provider keys backend-only.
ASSIST_PROVIDER_ORDER=groq,openrouter,openai
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TTS_PROVIDER_ORDER=openai,elevenlabs,compatible
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_NAME=Adam
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_STT_MODEL=scribe_v1
OPENAI_COMPATIBLE_TTS_BASE_URL=
OPENAI_COMPATIBLE_TTS_API_KEY=
OPENAI_COMPATIBLE_TTS_MODEL=gpt-4o-mini-tts
OPENAI_COMPATIBLE_TTS_VOICE=alloy
GAIA_ASSIST_VOICE_ENABLED=false

# Optional backend auth for the mobile app to staging proxy.
APP_PROXY_SHARED_SECRET=
